<html>
<head>
<style>
body{font-family:Arial}
h2{text-align:center}
table{width:100%;border-collapse:collapse}
td{border:1px solid #ccc;padding:8px}
</style>
</head>

<body>

<h2>Guest House Booking Request</h2>

<table>

<tr>
<td>Guest Name</td>
<td><%= guestName %></td>
</tr>

<tr>
<td>Gender</td>
<td><%= gender %></td>
</tr>

<tr>
<td>Address</td>
<td><%= address %></td>
</tr>

<tr>
<td>Contact</td>
<td><%= contactNumber %></td>
</tr>

<tr>
<td>No. Guests</td>
<td><%= numGuests %></td>
</tr>

<tr>
<td>No. Rooms</td>
<td><%= numRooms %></td>
</tr>

<tr>
<td>Arrival</td>
<td><%= arrivalDate %></td>
</tr>

<tr>
<td>Departure</td>
<td><%= departureDate %></td>
</tr>

<tr>
<td>Purpose</td>
<td><%= purpose %></td>
</tr>

</table>

</body>
</html>